# ============================================
# SavePro API - Environment Variables
# Add these to Vercel Dashboard > Settings > Environment Variables
# ============================================

# ============================================
# SECURITY (REQUIRED)
# ============================================

# Your API key for authentication
API_KEY=your_api_key_here


# ============================================
# OIDC AUTHENTICATION (REQUIRED for Production)
# ============================================

# VERCEL_OIDC_TOKEN: Automatically created when you enable OIDC
# Go to: Vercel Dashboard > Project Settings > Security > Enable OIDC
# This token is dynamically created by Vercel at runtime
# DO NOT set this manually - Vercel provides it automatically
VERCEL_OIDC_TOKEN=


# ============================================ 
# REDIS CACHE (Recommended - Cache-First Strategy)
# ============================================

# Option 1: Standard REDIS_URL (like your Redis Labs instance)
# Format: redis://username:password@host:port
REDIS_URL=redis://default:YOUR_PASSWORD@redis-xxxxx.c11.us-east-1-2.ec2.cloud.redislabs.com:19466


# Option 2: Upstash Redis (Alternative)
# Get these from your Upstash console: https://upstash.com/
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here


# ============================================
# AI GATEWAY (Optional - Fallback when direct requests fail)
# ============================================

# Get this from Vercel Dashboard > AI Gateway > API Keys
# Key format: vck_xxxxxxxxxxxxxxx
VERCEL_AI_API_KEY=vck_your_key_here


# ============================================
# RESIDENTIAL PROXY (Optional - For anti-bot protection)
# ============================================

# Example format: http://proxy-host:port or socks5://proxy-host:port
PROXY_URL=

# Proxy authentication credentials
PROXY_USER=
PROXY_PASS=


# ============================================
# RATE LIMITING (Smart - Based on Auth Status)
# ============================================

# Authorized requests (with valid OIDC): 500/min
# Unauthorized requests: 10/min
RATE_LIMIT_PER_IP=100
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_PER_KEY=500
RATE_LIMIT_VIDEO=10


# ============================================
# DEBUGGING
# ============================================

# Set to 'true' for verbose logging (disable in production)
DEBUG_MODE=false


# ============================================
# DEPLOYMENT CHECKLIST
# ============================================

# 1. Add all variables to Vercel Dashboard > Settings > Environment Variables
# 2. IMPORTANT: Enable OIDC from Project Settings > Security
#    - This will automatically create VERCEL_OIDC_TOKEN
#    - Without this, production requests will be blocked
# 3. For Development (local testing):
#    - Use Authorization: Bearer dev-token-for-testing header
#    - OIDC verification is automatically skipped in dev mode
# 4. All sensitive data is automatically scrubbed from logs


# ============================================
# API ENDPOINTS
# ============================================

# GET /api/info?url=TIKTOK_URL
# Headers: x-api-key, Authorization: Bearer <token>

# GET /api/download?url=VIDEO_URL&type=video|music
# Headers: x-api-key, Authorization: Bearer <token>


# ============================================
# SECURITY FEATURES
# ============================================

# ✓ Zero Trust Architecture with OIDC
# ✓ JWT signature verification
# ✓ Smart rate limiting (500/min authorized, 10/min unauthorized)
# ✓ Automatic credential scrubbing in logs
# ✓ All sensitive data protected