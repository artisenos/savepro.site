RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Upgrade any mixed HTTP content to HTTPS automatically
<IfModule mod_headers.c>
    Header always set Content-Security-Policy "upgrade-insecure-requests"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "DENY"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Allow direct access to PHP bridge and static files
RewriteCond %{REQUEST_URI} ^/api-bridge\.php$ [OR]
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Fallback for SPA routing (React Router) — all other routes go to index.html
RewriteRule ^ index.html [QSA,L]
